#!/usr/bin/env bash
# Called by jail to set up the sandbox filesystem inside a new mount namespace.
# Expects exported variables: NAME, CHDIR, WAYLAND, HAS_USERNS, JAIL_BINDS, JAIL_SETENV.
set -euo pipefail
NEW_ROOT="$(mktemp -d)"
mount -t tmpfs tmpfs "$NEW_ROOT"
mkdir -p "$NEW_ROOT/old_root"


mkdir -p "$NEW_ROOT/root"

# /dev
while IFS= read -r _dev_dir; do
  [ -z "$_dev_dir" ] && continue
  mkdir -p "$NEW_ROOT/$_dev_dir"
  mkdir -p "$NEW_ROOT/$_dev_dir/pts"
  mount -t devpts devpts "$NEW_ROOT/$_dev_dir/pts" -o newinstance,ptmxmode=0666
  ln -sf /dev/pts/ptmx "$NEW_ROOT/$_dev_dir/ptmx"
  mkdir -p "$NEW_ROOT/$_dev_dir/shm"
  chmod 1777 "$NEW_ROOT/$_dev_dir/shm"
  ln -s /proc/self/fd "$NEW_ROOT/$_dev_dir/fd"
  ln -s /proc/self/fd/0 "$NEW_ROOT/$_dev_dir/stdin"
  ln -s /proc/self/fd/1 "$NEW_ROOT/$_dev_dir/stdout"
  ln -s /proc/self/fd/2 "$NEW_ROOT/$_dev_dir/stderr"
  touch "$NEW_ROOT/$_dev_dir/null"
  touch "$NEW_ROOT/$_dev_dir/zero"
  touch "$NEW_ROOT/$_dev_dir/urandom"
  touch "$NEW_ROOT/$_dev_dir/random"
  mount --bind /dev/null "$NEW_ROOT/$_dev_dir/null"
  mount --bind /dev/zero "$NEW_ROOT/$_dev_dir/zero"
  mount --bind /dev/urandom "$NEW_ROOT/$_dev_dir/urandom"
  mount --bind /dev/random "$NEW_ROOT/$_dev_dir/random"
done <<< "$DEV_MOUNTS"

# /proc mounts
_temp_proc=false
if [ "$PID_NS" = true ]; then
  while IFS= read -r _proc_dir; do
    [ -z "$_proc_dir" ] && continue
    mkdir -p "$NEW_ROOT/$_proc_dir"
    mount -t proc proc "$NEW_ROOT/$_proc_dir"
  done <<< "$PROC_MOUNTS"

  # Check if /proc is already a mount point (for setup purposes)
  if ! mountpoint -q "$NEW_ROOT/proc"; then
    mkdir -p "$NEW_ROOT/proc"
    mount -t proc proc "$NEW_ROOT/proc"
    _temp_proc=true
  fi

else
  # if no PID namespace, use rbind to share /proc with the host
  while IFS= read -r _proc_dir; do
    [ -z "$_proc_dir" ] && continue
    mkdir -p "$NEW_ROOT/$_proc_dir"
    mount --rbind /proc "$NEW_ROOT/$_proc_dir"
  done <<< "$PROC_MOUNTS"

  # Check if /proc is already a mount point (for setup purposes)
  if ! mountpoint -q "$NEW_ROOT/proc"; then
    mkdir -p "$NEW_ROOT/proc"
    mount --rbind /proc "$NEW_ROOT/proc"
    _temp_proc=true
  fi
fi

# tmpfs mounts
while IFS= read -r _tmp_dir; do
  [ -z "$_tmp_dir" ] && continue
  mkdir -p "$NEW_ROOT/$_tmp_dir"
  mount -t tmpfs tmpfs "$NEW_ROOT/$_tmp_dir"
  chmod 0755 "$NEW_ROOT/$_tmp_dir" # to be in-line with bwrap's standard behavior
done <<< "$TMPFS_MOUNTS"


if [ "$NET_NS" = true ]; then
  mkdir -p "$NEW_ROOT/sys"
  mount --rbind /sys "$NEW_ROOT/sys" # required otherwise "ip netns exec" fails inside
fi

# Hostname, passwd, group
# TODO: can be replaced by jailnix fakepasswd
# mkdir -p "$NEW_ROOT/etc"
# printf "root:x:0:0:root:/root:/bin/sh\n" > "$NEW_ROOT/etc/passwd"
# printf "nobody:x:65534:65534:nobody:/var/empty:/bin/sh\n" >> "$NEW_ROOT/etc/passwd"
# printf "root:x:0:\n" > "$NEW_ROOT/etc/group"
# printf "nobody:x:65534:\n" >> "$NEW_ROOT/etc/group"
# printf "nogroup:x:65534:\n" >> "$NEW_ROOT/etc/group"
# printf "%s\n" "$NAME" > "$NEW_ROOT/etc/hostname"

# Bind mounts
while IFS= read -r _entry; do
  [ -z "$_entry" ] && continue
  _mode="${_entry%%:*}"; _rest="${_entry#*:}"
  _src="${_rest%%:*}"; _dst="${_rest#*:}"
  if [ -d "$_src" ]; then
    mkdir -p "$NEW_ROOT$_dst"
  else
    mkdir -p "$NEW_ROOT$(dirname "$_dst")"
    touch "$NEW_ROOT$_dst"
  fi
  mount --bind "$_src" "$NEW_ROOT$_dst"
  if [ "$_mode" = ro ]; then
    mount -o remount,ro,bind "$NEW_ROOT$_dst"
  fi

  # edge case: if we mount /proc, we need to set temp_proc to false so we don't unmount it later
if [[ "$_src" == /proc* ]]; then
    _temp_proc=false
  fi
done <<< "$JAIL_BINDS"

# TODO: can be replaced by jailnix wayland combinator
if [ "$WAYLAND" = true ]; then
  mkdir -p "$NEW_ROOT/run/user/0"
  touch "$NEW_ROOT/run/user/0/wayland-0"
  mount --rbind "$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY" "$NEW_ROOT/run/user/0/wayland-0"
  if [ -e /dev/dri ]; then
    mkdir -p "$NEW_ROOT/dev/dri"
    mount --bind /dev/dri "$NEW_ROOT/dev/dri"
  fi
  if [ -d /run/opengl-driver ]; then
    mkdir -p "$NEW_ROOT/run/opengl-driver"
    mount --bind /run/opengl-driver "$NEW_ROOT/run/opengl-driver"
  fi
fi

_ENV=(
  "PWD=$CHDIR"
  "HOME=/root"
  "USER=root"
  "TERM=${TERM:-}"
)

# TODO: can be replaced by jailnix wayland combinator
if [ "$WAYLAND" = true ]; then
  _ENV+=(
    "XDG_RUNTIME_DIR=/run/user/0"
    "WAYLAND_DISPLAY=wayland-0"
    "DISPLAY=${DISPLAY:-}"
    "NIXOS_OZONE_WL=${NIXOS_OZONE_WL:-}"
    "XDG_SESSION_TYPE=${XDG_SESSION_TYPE:-}"
  )
fi

# read additional environment variables from JAIL_SETENV
while IFS= read -r _e; do
  [ -n "$_e" ] && _ENV+=("$_e")
done <<< "$JAIL_SETENV"

# create working directory
mkdir -p "$NEW_ROOT$CHDIR"

if [ -n "$NAME" ]; then
  printf "%s\n" "${_ENV[@]}" > "/run/jail/$NAME/env"
  # write outer init PID of jail to fifo before pivot_root
  # use read builtin to not fork
  read -r _outer_pid _ < /proc/self/stat
  printf "%s\n" "$_outer_pid" > "/run/jail/$NAME/.pid_fifo"
fi

pivot_root "$NEW_ROOT" "$NEW_ROOT/old_root"

if [ "$HAS_USERNS" -ne 0 ] && [ "$NET_NS" = true ]; then
  mkdir -p "/sys"
  mount -t sysfs sysfs /sys # required for "ip netns exec" inside a user namespace
fi
cd /
umount -l /old_root
rmdir /old_root

# Clean up /proc only if we temporarily mounted it
if [ "$_temp_proc" = true ]; then
  umount -l /proc
  rmdir /proc
fi

# Symlinks (needs to be done after pivot_root since they point to other paths in the new root)
while IFS= read -r _entry; do
  [ -z "$_entry" ] && continue
  _src="${_entry%%:*}"; _dst="${_entry#*:}"
  mkdir -p "$(dirname "$_dst")"
  ln -s "$_src" "$_dst"
done <<< "$JAIL_SYMLINKS"

if [ -n "$NAME" ]; then
  if [ "$NEW_SESSION" = true ]; then
    setsid env -i --chdir "$CHDIR" "${_ENV[@]}" "$@"  # named jail: init handles signals itself
  else
    exec env -i --chdir "$CHDIR" "${_ENV[@]}" "$@"  # named jail: init handles signals itself
  fi
fi
# Run the command via setsid so a terminal SIGINT can't reach it directly; we
# forward signals to it as SIGTERM instead (a foreground job bypasses an INT trap
# but runs a TERM trap). Traps are installed before the child starts so an early
# signal can't tear the namespace down via the default handler.
_SIGNAL=0
# kill -- -1 signals every process in this pid namespace except us (PID 1).
trap '_SIGNAL=130; kill -s TERM -- -1 2>/dev/null' INT
trap '_SIGNAL=143; kill -s TERM -- -1 2>/dev/null' TERM

# Only create a new session if flag is specified, otherwise run env directly
if [ "$NEW_SESSION" = true ]; then
    setsid env -i --chdir "$CHDIR" "${_ENV[@]}" "$@" <&0 &
else
    exec env -i --chdir "$CHDIR" "${_ENV[@]}" "$@" <&0 &
fi

PID=$!
# '|| EXIT_CODE=$?' so set -e doesn't exit on the signal-killed child before the
# grace block below runs.
EXIT_CODE=0
wait "$PID" 2>/dev/null || EXIT_CODE=$?
if [ "$_SIGNAL" -ne 0 ]; then
  trap '' INT TERM  # ignore duplicate signals while cleanup runs
  # Let cleanup traps finish before we exit (and the kernel SIGKILLs the rest):
  # poll until the process table goes quiet, bounded by a deadline so a stuck
  # process can't hang teardown. We poll instead of wait because the command's
  # descendants aren't all our children, and named-jail inits stay alive by design.
  _deadline=$((SECONDS + 5)); _prev=-1; _settle=0
  while (( SECONDS < _deadline )); do
    _procs=(/proc/[0-9]*); _cur=${#_procs[@]}
    (( _cur == _prev )) && _settle=$((_settle + 1)) || _settle=0
    (( _settle >= 4 )) && break
    _prev=$_cur; sleep 0.05
  done
  exit "$_SIGNAL"
fi
trap - INT TERM
exit "$EXIT_CODE"
