#!/usr/bin/env bash
# Lightweight sandbox using Linux user/mount/net/pid namespaces and pivot_root.
# Named jails (jail add) pin namespaces under /run/jail/<name> and register the
# network namespace at /var/run/netns/<name>, making them compatible with ip netns.
# Commands: add <name> (create named jail), enter <name> <cmd> (re-enter), exec <cmd> (one-shot).
set -euo pipefail

_unshare_jail() {
  export NAME="$1"; shift

  export WAYLAND=false

  export DIE_WITH_PARENT=false
  export NEW_SESSION=false

  export USER_NS=false
  export NET_NS=false
  export UTS_NS=false
  export IPC_NS=false
  export CGROUP_NS=false
  export PID_NS=false

  export PROC_MOUNTS=""
  export DEV_MOUNTS=""
  export TMPFS_MOUNTS=""

  export CHDIR="/pwd"

  export JAIL_BINDS=""
  export JAIL_SYMLINKS=""
  export JAIL_SETENV=""

  while [[ "${1:-}" == --* ]]; do
    case "$1" in
      --wayland)        WAYLAND=true; shift ;;
      --bind)           _2_sanitized="${2#[\'\"]}"; _2_sanitized="${_2_sanitized%[\'\"]}"; _3_sanitized="${3#[\'\"]}"; _3_sanitized="${_3_sanitized%[\'\"]}";
                        JAIL_BINDS+="mode=rw,src=${_2_sanitized},dst=${_3_sanitized}"$'\n'; shift 3 ;;
      --ro-bind)        _2_sanitized="${2#[\'\"]}"; _2_sanitized="${_2_sanitized%[\'\"]}"; _3_sanitized="${3#[\'\"]}"; _3_sanitized="${_3_sanitized%[\'\"]}";
                        JAIL_BINDS+="mode=ro,src=${_2_sanitized},dst=${_3_sanitized}"$'\n'; shift 3 ;;
      --bind-try)       echo "jail: --bind-try is not implemented, use --bind instead" >&2; exit 1 ;;
      --ro-bind-try)    echo "jail: --ro-bind-try is not implemented, use --ro-bind instead" >&2; exit 1 ;;
      --dev-bind)       echo "jail: --dev-bind is not implemented, use --bind instead" >&2; exit 1 ;;
      --setenv)         _2_sanitized="${2#[\'\"]}"; _2_sanitized="${_2_sanitized%[\'\"]}"; _3_sanitized="${3#[\'\"]}"; _3_sanitized="${_3_sanitized%[\'\"]}";
                        JAIL_SETENV+="${_2_sanitized}=${_3_sanitized}"$'\n'; shift 3 ;;
      --symlink)        _2_sanitized="${2#[\'\"]}"; _2_sanitized="${_2_sanitized%[\'\"]}"; _3_sanitized="${3#[\'\"]}"; _3_sanitized="${_3_sanitized%[\'\"]}";
                        JAIL_SYMLINKS+="${_2_sanitized}:${_3_sanitized}"$'\n'; shift 3 ;;
      --chdir)          _sanitized="${2#[\'\"]}"; _sanitized="${_sanitized%[\'\"]}";
                        CHDIR="${_sanitized}"; shift 2 ;;
      --unshare-user)   USER_NS=true; shift ;;
      --unshare-net)    NET_NS=true; shift ;;
      --unshare-uts)    UTS_NS=true; shift ;;
      --unshare-ipc)    IPC_NS=true; shift ;;
      --unshare-cgroup) CGROUP_NS=true; shift ;;
      --unshare-pid)    PID_NS=true; shift ;;
      --unshare-all)    USER_NS=true; NET_NS=true; UTS_NS=true; IPC_NS=true; CGROUP_NS=true; PID_NS=true; shift ;;
      --proc)            _sanitized="${2#[\'\"]}"; _sanitized="${_sanitized%[\'\"]}";
                        PROC_MOUNTS="${_sanitized}"; shift 2 ;;
      --dev)            _sanitized="${2#[\'\"]}"; _sanitized="${_sanitized%[\'\"]}";
                        DEV_MOUNTS="${_sanitized}"; shift 2 ;;
      --tmpfs)          _sanitized="${2#[\'\"]}"; _sanitized="${_sanitized%[\'\"]}";
                        TMPFS_MOUNTS="${_sanitized}"; shift 2 ;;
      --clearenv)       JAIL_SETENV=""; shift ;;
      --die-with-parent) DIE_WITH_PARENT=true; shift ;;
      --new-session)    NEW_SESSION=true; shift ;;
      --args)
                        # Read nul-seperated args from FD
                        fd_args=()
                        while IFS= read -r -d $'\0' arg <&"$2"; do
                          read -r -a split_args <<< "$arg"
                          fd_args+=("${split_args[@]}")
                        done
                        shift 2
                        # Add the new arguments in front of remaining arguments
                        set -- "${fd_args[@]}" "$@"
                        ;;
      --)               shift ; break;;
      *) echo "jail: unknown flag: $1" >&2; exit 1 ;;
    esac
  done

  # Kill child arg
  local kill_child_arg=()
  if [ "$DIE_WITH_PARENT" = true ]; then
    kill_child_arg=("--kill-child=SIGKILL")
  fi


  # Ensure certain flags are set
  # Future work: Allow flags to be disabled and adjust behavior accordingly
   
   # NET_NS is enabled
  if [ "$NET_NS" != "true" ]; then
    echo "jail: Error: --unshare-net must be specified." >&2
    exit 1
  fi

  # PID_NS is enabled
  if [ "$PID_NS" != "true" ]; then
    echo "jail: Error: --unshare-pid must be specified." >&2
    exit 1
  fi

  # new session flag is supplied
  if [ "$NEW_SESSION" != "true" ]; then
    echo "jail: Error: --new-session must be specified." >&2
    exit 1
  fi

  # User Namespace
  # Only create if flag is specified or if the program is not run as root
  # If not run as root and --unshare-user is not specified, exit with error
  local user_args=()
  if [ "$(id -u)" -ne 0 ]; then
    if [ "$USER_NS" = true ]; then
      user_args=("--user" "--map-root-user")
    else
      echo "jail: Error: --unshare-user must be specified or program must be run as root." >&2
      exit 1
    fi
  fi

  # Net Namespace - is always created
  local net_arg=("--net")

  # UTS Namespace
  local uts_arg=()
  if [ "$UTS_NS" = true ]; then
    uts_arg=("--uts")
  fi

  # IPC Namespace
  local ipc_arg=()
  if [ "$IPC_NS" = true ]; then
    ipc_arg=("--ipc")
  fi

  # CGROUP Namespace
  local cgroup_arg=()
  if [ "$CGROUP_NS" = true ]; then
    cgroup_arg=("--cgroup")
  fi

  # Time Namespace - unchangeable for now - TODO
  local time_arg=("--time")

  # Mount Namespace - is always created
  local mnt_arg=("--mount")

  # PID Namespace - is always created
  local pid_arg=("--pid")

  if [ -n "$NAME" ]; then
    mkdir -p "/run/jail/$NAME"
    mkdir -p "/var/run/netns"
    touch "/run/jail/$NAME/user"
    touch "/var/run/netns/$NAME"
    if [ "$USER_NS" = true ]; then
      user_args=("--user=/run/jail/$NAME/user" "--map-root-user")
    fi

    net_arg=("--net=/var/run/netns/$NAME")
  
  fi

  export HAS_USERNS=${#user_args[@]}
  exec unshare \
    --keep-caps \
    --forward-signals \
    "${kill_child_arg[@]}" \
    "${user_args[@]}" \
    "${mnt_arg[@]}" \
    "${net_arg[@]}" \
    "${pid_arg[@]}" \
    --fork \
    "${uts_arg[@]}" \
    "${ipc_arg[@]}" \
    "${cgroup_arg[@]}" \
    "${time_arg[@]}" \
    -- bash "$(dirname "$0")/jail_setup" "$@"
}

_jail_enter() {
  local _name="$1"; shift
  # pid file indicates jail is ready
  if [ ! -f "/run/jail/$_name/pid" ]; then
    echo "jail enter: '$_name' does not exist" >&2
    exit 1
  fi

  local -a _env
  mapfile -t _env < "/run/jail/$_name/env"
  local _init_pid
  _init_pid="$(< "/run/jail/$_name/pid")"

  local _chdir
  _chdir="$(sed -n 's/^PWD=//p' "/run/jail/$_name/env")"

  if [ -e "/run/jail/$_name/user" ]; then
  local _user_arg=("--user=/run/jail/$_name/user")
  else 
    echo "jail enter: '$_name' does not have a user namespace. Enter jail as root." >&2
  fi

  # Mount Namespace is always created
  local _mnt_arg="--mount=/proc/$_init_pid/ns/mnt"

  local _net_arg=()
  if [ -e "/var/run/netns/$_name" ]; then
    _net_arg=("--net=/var/run/netns/$_name")
  fi

  local _pid_arg=()
  if [ "$(readlink /proc/1/ns/pid)" != "$(readlink "/proc/${_init_pid}/ns/pid")" ]; then
    _pid_arg=("--pid=/proc/${_init_pid}/ns/pid")
  fi

  local _uts_arg=()
  if [ "$(readlink /proc/1/ns/uts)" != "$(readlink "/proc/${_init_pid}/ns/uts")" ]; then
    _uts_arg=("--uts=/proc/${_init_pid}/ns/uts")
  fi

  local _ipc_arg=()
  if [ "$(readlink /proc/1/ns/ipc)" != "$(readlink "/proc/${_init_pid}/ns/ipc")" ]; then
    _ipc_arg=("--ipc=/proc/${_init_pid}/ns/ipc")
  fi

  # setpriv --pdeathsig TERM delivers SIGTERM to the entered command if its
  # nsenter parent is killed, so signalling a single `jail enter` tears down just
  # that command (running its cleanup trap) instead of orphaning it in the jail.
  exec nsenter \
    --preserve-credentials \
    "${_user_arg[@]}" \
    "${_mnt_arg[@]}" \
    "${_net_arg[@]}" \
    "${_pid_arg[@]}" \
    "${_uts_arg[@]}" \
    "${_ipc_arg[@]}" \
    -- setpriv --pdeathsig TERM \
    -- env \
      --ignore-environment \
      --chdir "$_chdir" \
      "${_env[@]}" \
      "$@"
}

_jail_exec() {
  _unshare_jail "" "$@"
}

_jail_add() {
  local _flags=()
  local _name=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --bind|--ro-bind|--setenv|--dev-bind|--bind-try|--ro-bind-try|--symlink) _flags+=("$1" "$2" "$3"); shift 3 ;;
      --chdir|--proc|--dev|--tmpfs|--args) _flags+=("$1" "$2"); shift 2 ;;
      --wayland|--unshare-user|--unshare-net|--unshare-uts|--unshare-ipc|--unshare-cgroup|--unshare-pid|--unshare-all|--clearenv|--die-with-parent|--new-session) _flags+=("$1"); shift ;;
      --)         shift ; break;;
      --*)        echo "jail add: unknown flag: $1" >&2; exit 1 ;;
      *)          # If it doesn't start with '--', it's the positional argument (jail name)
                  _name="$1"
                  shift ;;
    esac
  done
  
  if [ -z "$_name" ]; then
    echo "jail add: Jail name is required." >&2
    exit 1
  fi

  mkdir -p "/run/jail/$_name"
  # jail_setup writes outer init PID of jail to fifo when ready
  local _fifo="/run/jail/$_name/.pid_fifo"
  mkfifo "$_fifo"
  _unshare_jail "$_name" "${_flags[@]}" "$(command -v init)" &
  disown
  local _init_pid
  read -r _init_pid < "$_fifo" # FIXME: If the jail_setup fails, this will block forever
  rm -f "$_fifo"
  printf '%s\n' "$_init_pid" > "/run/jail/$_name/pid"
}

cmd="${1:-}"
shift || true

case "$cmd" in
  add)
    _jail_add "$@"
    ;;
  exec)
    _jail_exec "$@"
    ;;
  enter)
    _jail_enter "$@"
    ;;
  *)
    echo "usage: jail add <name> | jail exec <cmd>... | jail enter <name> <cmd>..." >&2
    exit 1
    ;;
esac
