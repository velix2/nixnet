#!/usr/bin/env bash
set -euo pipefail

pass() { echo "PASS: $*"; }
fail() { echo "FAIL: $*"; exit 1; }

# A direct SIGINT to the outer jail process exits it promptly.
jail exec --setenv "PATH=$PATH" bash -c "
  exec sleep 5
" &
PID=$!
sleep 0.2
kill -INT "$PID"
T=$SECONDS
wait "$PID" || true
(( SECONDS - T < 3 )) || fail "direct SIGINT: jail did not exit promptly"
pass "direct SIGINT exits the jail"


# A testbed using job control (set -m) and `wait` on a backgrounded nested enter
# still exits promptly: the SIGINT broadcast (kill -1) interrupts the wait.
jail exec --setenv "PATH=$PATH" bash -c "
  jail add --setenv PATH=$PATH myjail
  set -m
  jail enter myjail bash -c \"sleep 5\" &
  wait \$!
" &
PID=$!
sleep 0.2
kill -INT "$PID"
T=$SECONDS
wait "$PID" || true
(( SECONDS - T < 3 )) || fail "job-control wait: jail did not exit promptly on SIGINT"
pass "SIGINT exits a job-control wait"

# Job control defers SIGINT during a background-job wait; the forwarded TERM trap
# interrupts the wait immediately.
jail exec --setenv "PATH=$PATH" bash -c "
  set -m
  trap 'exit 130' INT TERM
  sleep 30 &
  wait \$!
" &
PID=$!
sleep 0.2
kill -INT "$PID"
T=$SECONDS
wait "$PID" || true
(( SECONDS - T < 3 )) || fail "TERM trap: did not exit promptly during job-control wait"
pass "TERM trap interrupts a job-control wait"

# Terminal Ctrl+C sends SIGINT to the whole process group. set -m gives the
# background jail its own group so kill -INT -- -$PID reaches unshare, jail_setup,
# the testbed bash and the foreground sleep, matching what the terminal sends.
set -m
jail exec --setenv "PATH=$PATH" bash -c "
  set -m
  PIDS=()
  WAIT_PIDS=()
  stop_pids() {
    for P in \"\${PIDS[@]}\"; do
      [ -n \"\$P\" ] || continue
      [ -e \"/proc/\$P\" ] || continue
      kill -INT -- -\"\$P\" 2>/dev/null || true
      wait \"\$P\" 2>/dev/null || true
    done
    PIDS=()
  }
  trap 'stop_pids; exit 130' INT TERM
  ( set +m; sleep 30 ) &
  PIDS+=(\$!)
  WAIT_PIDS+=(\$!)
  for P in \"\${WAIT_PIDS[@]}\"; do
    while kill -0 \"\$P\" 2>/dev/null; do
      sleep 0.1
    done
  done
" &
PID=$!
set +m
sleep 0.5
kill -INT -- -"$PID"
T=$SECONDS
wait "$PID" || true
(( SECONDS - T < 3 )) || fail "process-group SIGINT: testbed did not exit promptly"
pass "process-group SIGINT (Ctrl+C) exits the jail"

# SIGINT to the outer jail with a nested named jail must reach the inner process
# so it runs its cleanup trap.
PIPE=$(mktemp /tmp/sigint_test_XXXXXX)
trap 'rm -f "$PIPE"' EXIT
# Bind just the pipe file (at the same path) into both jails so the inner process
# can write to it. /proc/self/fd/N magic symlinks resolve in the current mount
# namespace, so they cannot be used when the path doesn't exist inside the jail.
jail exec --setenv "PATH=$PATH" --bind "$PIPE" "$PIPE" bash -c "
  jail add --setenv PATH=$PATH --bind $PIPE $PIPE myjail
  jail enter myjail bash -c \"
  trap 'echo signal >> $PIPE; exit 0' TERM INT
  echo ready >> $PIPE
  sleep 5
  \"
" &
PID=$!
until grep -q ready "$PIPE" 2>/dev/null; do sleep 0.05; done
kill -INT "$PID"
T=$SECONDS
wait "$PID" || true
grep -q signal "$PIPE" || fail "nested inner: signal was not delivered"
(( SECONDS - T < 3 )) || fail "nested inner: jail did not exit promptly"
pass "SIGINT reaches the nested inner process"

# Signalling a named jail's init directly (its outer-ns PID is in the pid file)
# must gracefully destroy the jail: forward the signal so the inner process runs
# its cleanup trap, then exit (tearing the namespace down). 'jail enter' returns
# once init has torn the namespace down.
PIPE=$(mktemp /tmp/sigint_test_XXXXXX)
trap 'rm -f "$PIPE"' EXIT
jail exec --setenv "PATH=$PATH" --bind "$PIPE" "$PIPE" bash -c "
  jail add --setenv PATH=$PATH --bind $PIPE $PIPE myjail
  jail enter myjail bash -c \"
  trap 'echo signal >> $PIPE; exit 0' TERM INT
  echo ready >> $PIPE
  sleep 5
  \" &
  until grep -q ready $PIPE 2>/dev/null; do sleep 0.05; done
  kill -INT \"\$(cat /run/jail/myjail/pid)\"
  T=\$SECONDS
  wait
  (( SECONDS - T >= 3 )) && { echo slow >> $PIPE; }
" &
PID=$!
wait "$PID" || true
grep -q signal "$PIPE" || fail "signal init: inner process did not get the signal"
grep -q slow "$PIPE" && fail "signal init: jail did not tear down promptly"
pass "signalling init destroys the jail"


# Two concurrent `jail enter`s in one named jail run independently and both finish
# at their own times (concurrently, ~3s — not serialised to ~5s).
PIPE=$(mktemp /tmp/sigint_test_XXXXXX)
trap 'rm -f "$PIPE"' EXIT
T=$SECONDS
jail exec --setenv "PATH=$PATH" --bind "$PIPE" "$PIPE" bash -c "
  jail add --setenv PATH=$PATH --bind $PIPE $PIPE myjail
  jail enter myjail bash -c 'sleep 2; echo done2 >> $PIPE' &
  jail enter myjail bash -c 'sleep 3; echo done3 >> $PIPE' &
  wait
"
{ grep -q done2 "$PIPE" && grep -q done3 "$PIPE"; } || fail "concurrent enters: both should complete"
(( SECONDS - T < 5 )) || fail "concurrent enters: ran serially, expected concurrent"
pass "concurrent enters run independently"

# Killing one `jail enter` tears down only that command — its inner work is
# terminated (via setpriv --pdeathsig), not orphaned — and the other enter in the
# same jail keeps running to completion.
PIPE=$(mktemp /tmp/sigint_test_XXXXXX)
trap 'rm -f "$PIPE"' EXIT
jail exec --setenv "PATH=$PATH" --bind "$PIPE" "$PIPE" bash -c "
  jail add --setenv PATH=$PATH --bind $PIPE $PIPE myjail
  jail enter myjail bash -c 'sleep 2; echo done2 >> $PIPE' &
  P_KILL=\$!
  jail enter myjail bash -c 'sleep 3; echo done3 >> $PIPE' &
  sleep 0.5
  kill \$P_KILL
  wait
"
grep -q done2 "$PIPE" && fail "isolated kill: killed enter kept running instead of terminating"
grep -q done3 "$PIPE" || fail "isolated kill: killing one enter affected another in the same jail"
pass "killing one enter leaves the others running"

# A named-jail child that catches SIGTERM and refuses to exit is still force-killed
# by init's SIGKILL fallback after the teardown deadline, so destroying the jail
# (by signalling init) tears it down instead of hanging.
PIPE=$(mktemp /tmp/sigint_test_XXXXXX)
trap 'rm -f "$PIPE"' EXIT
T=$SECONDS
jail exec --setenv "PATH=$PATH" --bind "$PIPE" "$PIPE" bash -c "
  jail add --setenv PATH=$PATH --bind $PIPE $PIPE myjail
  jail enter myjail bash -c \"
    trap 'echo got-term >> $PIPE' TERM   # catch SIGTERM but never exit
    trap '' INT
    echo ready >> $PIPE
    while true; do sleep 0.2; done
  \" 2>/dev/null &
  until grep -q ready $PIPE 2>/dev/null; do sleep 0.05; done
  kill -INT \"\$(cat /run/jail/myjail/pid)\"
  wait
"
DUR=$((SECONDS - T))
grep -q got-term "$PIPE" || fail "SIGKILL fallback: child never received SIGTERM from init"
(( DUR >= 4 )) || fail "SIGKILL fallback: torn down too fast — a SIGTERM-ignoring child should force the deadline"
(( DUR < 8 )) || fail "SIGKILL fallback: jail hung; init did not SIGKILL the unresponsive child"
pass "SIGTERM-ignoring child is SIGKILLed"

# A jailed command's exit code propagates back to the caller, through both
# `jail enter` and the outer `jail exec`.
code=0
jail exec --setenv "PATH=$PATH" bash -c "
  jail add --setenv PATH=$PATH myjail
  jail enter myjail bash -c 'exit 37'
  exit \$?
" || code=$?
(( code == 37 )) || fail "exit code: expected 37 to propagate, got $code"
pass "exit codes propagate to the caller"
